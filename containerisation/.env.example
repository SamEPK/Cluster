# ============================================================
# LottoTi — Environment Configuration
# Copy to .env and fill in real values before deployment.
#
# Generate secrets with: openssl rand -hex 32
# ============================================================

# === Application ===
FLASK_ENV=production

# === Security Secrets (REQUIRED — min 32 chars, random) ===
# Generate with: openssl rand -hex 32
FLASK_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
JWT_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32

# === Database ===
# Password for PostgreSQL (auto-used in docker-compose DATABASE_URL)
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# === Stripe Payments (optional — required for payment features) ===
# Get keys from: https://dashboard.stripe.com/apikeys
# Use sk_test_* for staging, sk_live_* for production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# === Frontend URL (REQUIRED — used for CORS and email links) ===
# Set to your domain in production (e.g., https://lottoti.com)
FRONTEND_URL=http://localhost
CORS_ORIGINS=http://localhost

# === Monitoring (optional but recommended) ===
# Get DSN from: https://sentry.io/ → Project Settings → Client Keys
SENTRY_DSN=
# Valid values: debug, info, warning, error, critical
LOG_LEVEL=info

# === Ports ===
NGINX_PORT=80
NGINX_SSL_PORT=443

# === Database Seeding ===
# Set to true on FIRST deploy only — automatically disabled after
SEED_DB=false
